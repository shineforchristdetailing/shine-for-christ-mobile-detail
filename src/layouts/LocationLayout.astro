---
import BaseLayout from './BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import CTASection from '../components/CTASection.astro';
import { business } from '../data/business';

interface Props {
  city: string;
  title: string;
  description: string;
  content: string;
  nearbyAreas: string[];
}

const { city, title, description, content, nearbyAreas } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-primary py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Mobile Car Detailing in {city}, FL</h1>
      <p class="text-lg text-blue-100 max-w-2xl mb-8">Professional mobile auto detailing services delivered right to your door in {city}. No drop-off needed — we come to you.</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={`tel:${business.phoneTel}`} class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {business.phone}
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors border border-white/20">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <article class="prose prose-lg max-w-none text-gray leading-relaxed" set:html={content} />
    </div>
  </section>

  <!-- Services Summary -->
  <section class="py-16 bg-light">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-dark text-center mb-8">Our Services in {city}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <h3 class="text-xl font-bold text-dark mb-2">Exterior Detail</h3>
          <p class="text-sm text-gray mb-3">Hand wash, clay bar, polish, and wax. Call for pricing.</p>
          <a href="tel:+17542144977" class="text-primary font-semibold text-sm">Call to Book &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <h3 class="text-xl font-bold text-dark mb-2">Interior Detail</h3>
          <p class="text-sm text-gray mb-3">Deep clean, steam, leather care, odor removal. Call for pricing.</p>
          <a href="tel:+17542144977" class="text-primary font-semibold text-sm">Call to Book &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <h3 class="text-xl font-bold text-dark mb-2">Full Detail Package</h3>
          <p class="text-sm text-gray mb-3">Complete inside and out transformation. Call for pricing.</p>
          <a href="tel:+17542144977" class="text-primary font-semibold text-sm">Call to Book &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Nearby Areas -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-dark mb-4">Also Serving Nearby Areas</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {nearbyAreas.map((area) => (
          <span class="bg-light border border-gray-light rounded-full px-4 py-2 text-sm font-medium text-dark">{area}, FL</span>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
  <ContactForm heading={`Contact Us in ${city}`} />
</BaseLayout>
