---
import { business } from '../data/business';
const year = new Date().getFullYear();
---

<footer class="bg-dark text-white">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Business Info -->
      <div>
        <h3 class="text-lg font-bold mb-3">{business.shortName}</h3>
        <p class="text-gray-400 text-sm mb-4">Professional mobile auto detailing serving the {business.primaryCity}. We come to your home, office, or anywhere you need us.</p>
        <div class="flex items-center gap-2 text-sm text-gray-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <a href={`tel:${business.phoneTel}`} class="hover:text-accent">{business.phone}</a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm text-gray-300">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li><a href="/#services" class="hover:text-accent transition-colors">Services</a></li>
          <li><a href="/contact" class="hover:text-accent transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Service Areas -->
      <div>
        <h3 class="text-lg font-bold mb-3">Service Areas</h3>
        <ul class="space-y-1 text-sm text-gray-300 columns-2">
          {business.serviceAreas.map((city) => (
            <li>{city}</li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 mt-8 pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-400">&copy; {year} {business.name}. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href={business.facebook} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent transition-colors" aria-label="Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
