---
import { business } from '../data/business';
---

<section class="bg-primary py-16">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready for a Showroom Shine?</h2>
    <p class="text-lg text-blue-200 mb-8">Call or text us today to schedule your detail. We come to you — home, office, or anywhere in the {business.primaryCity}.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`tel:${business.phoneTel}`}
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {business.phone}
      </a>
      <a
        href={`sms:${business.phoneTel}`}
        class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors border border-white/20"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        Text Us
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-white hover:bg-gray-100 text-primary font-bold px-8 py-4 rounded-lg text-lg transition-colors"
      >
        Contact Us
      </a>
    </div>
  </div>
</section>
