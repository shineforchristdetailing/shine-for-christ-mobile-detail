<LocationLayout
  city="St. Petersburg"
  title="Mobile Car Detailing St. Petersburg FL | Shine For Christ"
  description="Professional mobile car detailing in St. Petersburg, FL. We come to you! Full detail packages, ceramic coating, interior cleaning. Call 754-214-4977."
  content={content}
  nearbyAreas={['Gulfport', 'Pinellas Park', 'Treasure Island', 'Madeira Beach', 'Kenneth City', 'Seminole']}
/>
