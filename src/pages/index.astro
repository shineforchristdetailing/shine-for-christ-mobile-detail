---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import { business } from '../data/business';

const galleryImages = [
  { src: '/images/gallery/image_1.jpg', alt: 'Shine For Christ mobile detailing trailer fully equipped and ready for service', caption: 'Our Fully Equipped Mobile Detailing Unit' },
  { src: '/images/gallery/image_2.jpg', alt: 'Happy customer with freshly detailed red Ford Flex', caption: 'Another Happy Customer' },
  { src: '/images/gallery/image_3.jpg', alt: 'Detailing a blue SUV - exterior hand wash and tire cleaning', caption: 'Exterior Detail in Progress' },
  { src: '/images/gallery/image_4.jpg', alt: 'Freshly detailed white sports car with showroom shine', caption: 'Showroom Shine Results' },
  { src: '/images/gallery/image_5.jpg', alt: 'Commercial truck detailing - we detail vehicles of all sizes', caption: 'We Detail Vehicles of All Sizes' },
  { src: '/images/gallery/image_6.jpg', alt: 'Freshly detailed black Tesla Model X looking brand new', caption: 'Premium Detail on a Tesla Model X' },
];
---

<BaseLayout
  title="Shine For Christ Mobile Auto Detailing | Tampa Bay Area"
  description="Professional mobile car detailing in the Tampa Bay Area. We come to you! Exterior, interior, and full detail packages. Call 754-214-4977 today."
>
  <!-- Hero Section -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary to-primary-light opacity-90"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-20 md:py-28">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Professional Mobile Auto Detailing — <span class="text-accent">We Come to You</span>
        </h1>
        <p class="text-lg md:text-xl text-blue-100 mb-8 max-w-2xl">
          Serving the {business.primaryCity} with premium car detailing at your home, office, or anywhere you need. Your car deserves a showroom shine.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={`tel:${business.phoneTel}`}
            class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {business.phone}
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-lg text-lg transition-colors border border-white/20"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16 bg-white" id="services">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Our Detailing Services</h2>
        <p class="text-gray max-w-2xl mx-auto">From a quick exterior wash to a full interior and exterior detail, we offer packages to fit every vehicle and budget.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Exterior -->
        <div class="bg-light rounded-xl p-6 text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2">Exterior Detail</h3>
          <p class="text-gray text-sm mb-4">Hand wash, clay bar treatment, polish, and wax. Your paint will look brand new.</p>
          <a href="tel:+17542144977" class="text-primary font-semibold text-sm hover:text-primary-light">Call to Book &rarr;</a>
        </div>
        <!-- Interior -->
        <div class="bg-light rounded-xl p-6 text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2">Interior Detail</h3>
          <p class="text-gray text-sm mb-4">Deep vacuum, steam clean, leather conditioning, and odor elimination. Fresh and spotless.</p>
          <a href="tel:+17542144977" class="text-primary font-semibold text-sm hover:text-primary-light">Call to Book &rarr;</a>
        </div>
        <!-- Full Detail -->
        <div class="bg-light rounded-xl p-6 text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2">Full Detail Package</h3>
          <p class="text-gray text-sm mb-4">The complete treatment inside and out. Our most popular package for a total transformation.</p>
          <a href="tel:+17542144977" class="text-primary font-semibold text-sm hover:text-primary-light">Call to Book &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Carousel -->
  <ImageCarousel images={galleryImages} />

  <!-- Why Choose Us -->
  <section class="py-16 bg-light">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Why Choose Shine For Christ?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-dark mb-2">We Come to You</h3>
          <p class="text-sm text-gray">Home, office, or wherever your vehicle is. No need to drive anywhere.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-bold text-dark mb-2">Professional Grade</h3>
          <p class="text-sm text-gray">We use top-quality products and proven techniques for lasting results.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-dark mb-2">Flexible Scheduling</h3>
          <p class="text-sm text-gray">Book a time that works for you. Weekday, weekend, or evening appointments.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-dark mb-2">Faith-Driven Service</h3>
          <p class="text-sm text-gray">We operate with integrity, honesty, and a commitment to excellence in everything we do.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews / Facebook -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">What Our Customers Say</h2>
        <p class="text-gray max-w-2xl mx-auto">Don't just take our word for it — check out our reviews and before &amp; after photos on Facebook.</p>
      </div>

      <!-- Facebook Reviews CTA -->
      <div class="bg-[#f0f2f5] rounded-2xl p-8 md:p-10 max-w-3xl mx-auto text-center mb-10">
        <div class="flex justify-center mb-4">
          <svg class="w-12 h-12 text-[#1877F2]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-dark mb-2">See Our Reviews on Facebook</h3>
        <p class="text-gray text-sm mb-6">Real reviews from real customers. See the results for yourself — browse our before &amp; after photos, customer feedback, and latest work.</p>
        <a
          href={`${business.facebook}reviews/`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#1877F2] hover:bg-[#0d65d9] text-white font-bold px-8 py-3.5 rounded-lg text-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
          Read Our Reviews
        </a>
      </div>

      <!-- Highlight cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-light rounded-xl p-6">
          <div class="flex items-center gap-1 mb-3">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray text-sm mb-4">"Amazing attention to detail. My car hasn't looked this good since I drove it off the lot. The mobile service makes it so easy."</p>
          <p class="font-semibold text-dark text-sm">— Facebook Review</p>
        </div>
        <div class="bg-light rounded-xl p-6">
          <div class="flex items-center gap-1 mb-3">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray text-sm mb-4">"Professional, on time, and the results speak for themselves. Inside and out, my SUV looks brand new. Highly recommend!"</p>
          <p class="font-semibold text-dark text-sm">— Facebook Review</p>
        </div>
        <div class="bg-light rounded-xl p-6">
          <div class="flex items-center gap-1 mb-3">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray text-sm mb-4">"Great price, great service. They came right to my driveway and did an incredible job. Will definitely be using them again."</p>
          <p class="font-semibold text-dark text-sm">— Facebook Review</p>
        </div>
      </div>

      <p class="text-center mt-6">
        <a href={`${business.facebook}reviews/`} target="_blank" rel="noopener noreferrer" class="text-[#1877F2] font-semibold hover:underline inline-flex items-center gap-1">
          See all reviews on Facebook
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
      </p>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-16 bg-light">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Serving the {business.primaryCity}</h2>
        <p class="text-gray max-w-2xl mx-auto">We proudly serve the following cities and surrounding communities. Don't see your area? Give us a call — we may still be able to come to you.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        {business.serviceAreas.map((city) => (
          <span class="bg-white border border-gray-light rounded-full px-4 py-2 text-sm font-medium text-dark">{city}, FL</span>
        ))}
      </div>
      <div class="text-center">
        <a href="/contact" class="inline-flex items-center gap-2 bg-primary hover:bg-primary-light text-white font-semibold px-6 py-3 rounded-lg transition-colors">
          Check if We Serve Your Area
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection />

</BaseLayout>
