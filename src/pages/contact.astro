---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { business } from '../data/business';
---

<BaseLayout
  title="Contact Us | Shine For Christ Mobile Auto Detailing"
  description="Contact us for mobile car detailing in the Tampa Bay Area. Call, text, or fill out our form. We come to you!"
>
  <!-- Page Header -->
  <section class="bg-primary py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Contact Us</h1>
      <p class="text-lg text-blue-100 max-w-2xl mx-auto">Ready to get your vehicle looking its best? Reach out for a free, no-obligation quote. We respond fast.</p>
    </div>
  </section>

  <!-- Contact Options -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <!-- Call -->
        <a
          href={`tel:${business.phoneTel}`}
          class="flex flex-col items-center bg-light rounded-xl p-8 text-center hover:shadow-lg transition-shadow group"
        >
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-dark mb-2">Call Us</h2>
          <p class="text-primary font-semibold text-lg">{business.phone}</p>
          <p class="text-sm text-gray mt-1">Tap to call now</p>
        </a>

        <!-- Text -->
        <a
          href={`sms:${business.phoneTel}`}
          class="flex flex-col items-center bg-light rounded-xl p-8 text-center hover:shadow-lg transition-shadow group"
        >
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-dark mb-2">Text Us</h2>
          <p class="text-primary font-semibold text-lg">{business.phone}</p>
          <p class="text-sm text-gray mt-1">Tap to send a text</p>
        </a>

        <!-- Facebook -->
        <a
          href={business.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center bg-light rounded-xl p-8 text-center hover:shadow-lg transition-shadow group"
        >
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
            <svg class="w-8 h-8 text-primary" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-dark mb-2">Facebook</h2>
          <p class="text-primary font-semibold text-sm">Message us on Facebook</p>
          <p class="text-sm text-gray mt-1">See our latest work</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <ContactForm heading="Send Us a Message" />

  <!-- Service Area -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-dark mb-4">Service Area</h2>
      <p class="text-gray mb-6">We provide mobile auto detailing throughout the {business.primaryCity}, including:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {business.serviceAreas.map((city) => (
          <span class="bg-light border border-gray-light rounded-full px-4 py-2 text-sm font-medium text-dark">{city}</span>
        ))}
      </div>
      <p class="text-sm text-gray mt-6">Don't see your city? Contact us — we may still serve your area.</p>
    </div>
  </section>
</BaseLayout>
